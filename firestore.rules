rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to verify authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to verify user matches requested UID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      // Allow searching and viewing profiles by any authenticated user
      allow read: if isAuthenticated();
      // Allow creation only at sign up for the matching UID
      allow create: if isOwner(userId);
      // Allow update of status/displayName only by the owner
      allow update: if isOwner(userId) 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'status', 'photoUrl']);
      // Profiles cannot be deleted
      allow delete: if false;
    }

    // 2. Contacts Collection
    match /contacts/{contactId} {
      // Allow read if the user is one of the parties of the contact document
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.contactUserId == request.auth.uid);
      // Contact records are generated by the friend request flow (written by either participant on accept)
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || request.resource.data.contactUserId == request.auth.uid);
      // Contacts cannot be updated or deleted directly
      allow update, delete: if false;
    }

    // 3. Friend Requests Collection
    match /friend_requests/{requestId} {
      // Read if caller is sender or recipient
      allow read: if isAuthenticated() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      // Create if sender matches auth user, status is pending
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid && request.resource.data.status == 'pending';
      // Update states: recipient accepts/declines, sender cancels
      allow update: if isAuthenticated() && (
        (resource.data.toUserId == request.auth.uid && request.resource.data.status in ['accepted', 'declined']) ||
        (resource.data.fromUserId == request.auth.uid && request.resource.data.status == 'cancelled')
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      // Friend requests cannot be deleted
      allow delete: if false;
    }

    // 4. Call History Collection
    match /callHistory/{callId} {
      // Read and create call records if user is caller or receiver
      allow read: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.callerId == request.auth.uid || request.resource.data.receiverId == request.auth.uid);
      // History cannot be updated or deleted
      allow update, delete: if false;
    }
  }
}
